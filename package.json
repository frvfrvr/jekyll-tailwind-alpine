{
  "name": "jekyll-tailwind-alpine",
  "version": "1.0.0",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/main.css",
    "watch:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/main.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"bundle exec jekyll serve\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.1"
  },
  "dependencies": {
    "alpinejs": "^3.13.5"
  }
}